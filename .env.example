# Temporal (post-scheduling worker). Omit TEMPORAL_ADDRESS to disable Temporal
# and let the backend start without it (scheduling features won't work).
# TEMPORAL_ADDRESS="localhost:7233"
# TEMPORAL_NAMESPACE="default"
# TEMPORAL_TLS="false"
# TEMPORAL_API_KEY=""