# Configuration reference: http://docs.postiz.com/configuration/reference

# === Railway Postgres (users, orgs, posts — Prisma)
# Railway injects these when Postgres is linked to a service (variable names match Railway’s UI):
#   DATABASE_URL          — private URL (postgres.${{RAILWAY_PRIVATE_DOMAIN}}:5432) for services inside Railway
#   DATABASE_PUBLIC_URL   — TCP proxy URL for connections from your laptop / CI
#
# Deployed backend on Railway: link the Postgres plugin; DATABASE_URL is set automatically (use that).
#
# Local dev against cloud Postgres: either
#   (A) Set DATABASE_PUBLIC_URL to the value from Railway → Postgres → Variables → DATABASE_PUBLIC_URL
#       and leave DATABASE_URL unset or empty — the backend maps it and adds sslmode=require if missing, OR
#   (B) Set POSTGRES_* credentials plus RAILWAY_TCP_PROXY_DOMAIN and RAILWAY_TCP_PROXY_PORT (same names as on the Postgres
#       service in Railway) — the backend and scripts build DATABASE_URL from those, OR
#   (C) Paste DATABASE_PUBLIC_URL (or the public “Connect” string) directly as DATABASE_URL and add ?sslmode=require if Prisma errors.
#
# Prisma CLI: use `pnpm run prisma-db-push:railway` to read DATABASE_PUBLIC_URL from .env when DATABASE_URL is unset,
# or set DATABASE_URL to the public connection string and run `pnpm prisma-db-push` as usual.
#
# Railway deploy (see repo nixpacks.toml): backend build + start are wired for Nixpacks.
# If you see "Cannot find module '/app/index.js'", the root package.json must not use main:index.js
# and the Start Command should be `pnpm run start:prod:backend` (or rely on nixpacks.toml [start]).
# Frontend service: set Build to include `pnpm run build:frontend` and Start to `pnpm run start:prod:frontend`.

# === Required Settings
# Local Docker Postgres (default example):
DATABASE_URL="postgresql://postiz-user:postiz-password@localhost:5432/postiz-db-local"
# Railway public proxy (optional; leave DATABASE_URL unset to use only this for local backend — see note above):
# DATABASE_PUBLIC_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="random string for your JWT secret, make it long"

# Block public signup (backend + OAuth new users) once at least one org exists; pair with frontend hiding Sign Up.
# DISABLE_REGISTRATION="true"
#
# Create a platform super-admin (LOCAL login, isSuperAdmin, own org). Requires JWT_SECRET, ADMIN_EMAIL, ADMIN_PASSWORD,
# and a resolvable DB URL (DATABASE_URL, DATABASE_PUBLIC_URL, or TCP proxy vars + POSTGRES_*):
#   pnpm run create-super-admin

# === This needs to be exactly the URL you're accessing Postiz on
FRONTEND_URL="http://localhost:4200"
# Public URL of the API (must include scheme). Used by the backend for MCP/OAuth URL building — set on Railway to your backend service URL, e.g. https://postiz-api.up.railway.app
NEXT_PUBLIC_BACKEND_URL="http://localhost:3000"
BACKEND_INTERNAL_URL="http://localhost:3000"

## Remember to set your public internet IP address in the allow-list for the API token.
##
## Cloudflare is currently required to save things like social media avatars for accounts.
CLOUDFLARE_ACCOUNT_ID="your-account-id"
CLOUDFLARE_ACCESS_KEY="your-access-key"
CLOUDFLARE_SECRET_ACCESS_KEY="your-secret-access-key"
CLOUDFLARE_BUCKETNAME="your-bucket-name"
CLOUDFLARE_BUCKET_URL="https://your-bucket-url.r2.cloudflarestorage.com/"
CLOUDFLARE_REGION="auto"

# === Common optional Settings

## This is a dummy key, you must create your own from Resend.
## If this variable exists, user activation is required.
## If it is commented out, users are activated automatically.
#RESEND_API_KEY="RzeTwHijvxvPUerScFcenUZUALuQJzSaGSMJ"
#EMAIL_FROM_ADDRESS=""
#EMAIL_FROM_NAME=""
#DISABLE_REGISTRATION=false

# Where media is stored: "local" (disk) or "cloudflare" (R2). You do NOT need Cloudflare on Railway for local.
STORAGE_PROVIDER="local"

# Absolute path on the server where uploads are written. On Railway: use a persistent volume mount, e.g.
#   UPLOAD_DIRECTORY="/data/uploads"
# Then in Railway → postiz-app → Volumes: mount a volume at /data/uploads (files survive redeploys).
UPLOAD_DIRECTORY="/tmp/postiz-uploads"

# Browser-facing origin for file URLs when STORAGE_PROVIDER=local. On Railway with only the API service,
# set this to your backend public URL (same as NEXT_PUBLIC_BACKEND_URL) so /uploads/* hits Nest static files.
# If you use a separate Next.js service that serves /api/uploads, set FRONTEND_URL to that app instead.
#LOCAL_UPLOAD_PUBLIC_URL="https://your-backend.up.railway.app"

#NEXT_PUBLIC_UPLOAD_STATIC_DIRECTORY=""

